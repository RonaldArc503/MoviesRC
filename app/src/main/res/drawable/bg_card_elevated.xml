<?xml version="1.0" encoding="utf-8"?>
<!--
    Card con elevación y sombra para destacar
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Estado enfocado (TV) -->
    <item android:state_focused="true">
        <layer-list>
            <!-- Sombra -->
            <item>
                <shape>
                    <solid android:color="#40000000" />
                    <corners android:radius="12dp" />
                </shape>
            </item>
            <!-- Card principal -->
            <item
                android:left="2dp"
                android:top="2dp"
                android:right="2dp"
                android:bottom="6dp">
                <shape>
                    <solid android:color="@color/rexCard" />
                    <corners android:radius="10dp" />
                    <stroke android:width="3dp" android:color="@color/accentRed" />
                </shape>
            </item>
        </layer-list>
    </item>
    <!-- Estado normal -->
    <item>
        <shape>
            <solid android:color="@color/rexCard" />
            <corners android:radius="10dp" />
        </shape>
    </item>
</selector>

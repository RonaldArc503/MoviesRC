<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app_dark"
    android:fitsSystemWindows="true">

    <View
        android:layout_width="match_parent"
        android:layout_height="160dp"
        android:background="@drawable/gradient_hero_fade" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_home_sections"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:overScrollMode="never"
        android:paddingTop="24dp"
        android:paddingBottom="100dp" />

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:indeterminateTint="@color/accentRed"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/bottom_menu"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_gravity="bottom"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/bg_toolbar_scrim"
        android:elevation="12dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingStart="4dp"
        android:paddingEnd="4dp">

        <LinearLayout
            android:id="@+id/menu_home"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/bg_tv_menu_item"
            android:clickable="true"
            android:focusable="false"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_home"
                android:tint="@color/textMuted" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Inicio"
                android:textColor="@color/textMuted"
                android:textSize="10sp"
                android:maxLines="1" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/menu_buscar"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/bg_tv_menu_item"
            android:clickable="true"
            android:focusable="false"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_search"
                android:tint="@color/textMuted" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Buscar"
                android:textColor="@color/textMuted"
                android:textSize="10sp"
                android:maxLines="1" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/menu_canales"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/bg_tv_menu_item"
            android:clickable="true"
            android:focusable="false"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_chanels"
                android:tint="@color/textMuted" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Canales"
                android:textColor="@color/textMuted"
                android:textSize="10sp"
                android:maxLines="1" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/menu_football"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/bg_tv_menu_item"
            android:clickable="true"
            android:focusable="false"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_sports"
                android:tint="@color/textMuted" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Deportes"
                android:textColor="@color/textMuted"
                android:textSize="10sp"
                android:maxLines="1" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/menu_categorias"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/bg_tv_menu_item"
            android:clickable="true"
            android:focusable="false"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_grid"
                android:tint="@color/textMuted" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Categorías"
                android:textColor="@color/textMuted"
                android:textSize="10sp"
                android:maxLines="1" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/menu_series"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/bg_tv_menu_item"
            android:clickable="true"
            android:focusable="false"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="gone">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_series"
                android:tint="@color/textMuted" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Series"
                android:textColor="@color/textMuted"
                android:textSize="10sp"
                android:maxLines="1" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/menu_doramas"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/bg_tv_menu_item"
            android:clickable="true"
            android:focusable="false"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="gone">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_tv"
                android:tint="@color/textMuted" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Doramas"
                android:textColor="@color/textMuted"
                android:textSize="10sp"
                android:maxLines="1" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/menu_ajustes"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/bg_tv_menu_item"
            android:clickable="true"
            android:focusable="false"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="gone">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_settings"
                android:tint="@color/textMuted" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Ajustes"
                android:textColor="@color/textMuted"
                android:textSize="10sp"
                android:maxLines="1" />
        </LinearLayout>
    </LinearLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>

<?xml version="1.0" encoding="utf-8"?>
<!--
    item_hero_banner.xml – Banner hero estilo Netflix
    Muestra contenido destacado con imagen de fondo, gradiente y botones de acción
-->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="520dp"
    app:cardCornerRadius="0dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@color/rexBackground">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Imagen de backdrop -->
        <ImageView
            android:id="@+id/iv_hero_backdrop"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@drawable/placeholder_backdrop" />

        <!-- Gradiente superior oscuro -->
        <View
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:layout_gravity="top"
            android:background="@drawable/gradient_hero_fade" />

        <!-- Gradiente inferior con información -->
        <View
            android:layout_width="match_parent"
            android:layout_height="320dp"
            android:layout_gravity="bottom"
            android:background="@drawable/bg_hero_gradient" />

        <!-- Contenido del banner -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingBottom="28dp">

            <!-- Título del contenido -->
            <TextView
                android:id="@+id/tv_hero_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Título del Contenido"
                android:textColor="@color/white"
                android:textSize="32sp"
                android:textStyle="bold"
                android:lineSpacingExtra="2dp"
                android:shadowColor="#000000"
                android:shadowDx="2"
                android:shadowDy="2"
                android:shadowRadius="4"
                android:maxLines="2"
                android:ellipsize="end" />

            <!-- Metadatos (año, rating, tipo) -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tv_hero_year"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2024"
                    android:textColor="@color/accentGold"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <View
                    android:layout_width="4dp"
                    android:layout_height="4dp"
                    android:layout_marginStart="10dp"
                    android:layout_marginEnd="10dp"
                    android:background="@drawable/dot_separator" />

                <TextView
                    android:id="@+id/tv_hero_rating"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="★ 8.5"
                    android:textColor="@color/ratingGold"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:visibility="gone" />

            </LinearLayout>

            <!-- Sinopsis breve -->
            <TextView
                android:id="@+id/tv_hero_synopsis"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Una breve descripción del contenido destacado..."
                android:textColor="@color/textSecondary"
                android:textSize="13sp"
                android:lineSpacingExtra="2dp"
                android:maxLines="3"
                android:ellipsize="end" />

            <!-- Botones de acción -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="20dp">

                <!-- Botón Reproducir -->
                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btn_hero_play"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_btn_play_red"
                    android:text="▶ Reproducir"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textAllCaps="false" />

                <!-- Botón Más Info -->
                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btn_hero_info"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_btn_secondary"
                    android:text="ⓘ Más Info"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textAllCaps="false" />

            </LinearLayout>

        </LinearLayout>

        <!-- Indicadores de página (para carrusel) -->
        <LinearLayout
            android:id="@+id/ll_hero_indicators"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginBottom="8dp"
            android:orientation="horizontal"
            android:visibility="gone" />

    </FrameLayout>

</androidx.cardview.widget.CardView>

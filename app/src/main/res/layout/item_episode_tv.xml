<?xml version="1.0" encoding="utf-8"?>
<!--
    item_episode_tv.xml — Ítem de episodio para RecyclerView en TV
    Res: res/layout/item_episode_tv.xml

    IDs requeridos por EpisodeAdapter:
      • tv_episode_code  → "Episodio N"
      • tv_episode_title → título del episodio

    TV D-pad:
      • focusable="true" en la raíz
      • background: selector_episode_item_tv (borde rojo al tener foco)
      • nextFocusLeft → @id/btn_like
      • minHeight 56dp (target cómodo sin ser gigante)
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:minHeight="56dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="10dp"
    android:paddingEnd="10dp"
    android:paddingTop="7dp"
    android:paddingBottom="7dp"
    android:focusable="true"
    android:focusableInTouchMode="true"
    android:background="@drawable/selector_episode_item_tv"
    android:nextFocusLeft="@id/btn_like">

    <!-- ── Código: "Episodio N" — pequeño, color apagado ── -->
    <TextView
        android:id="@+id/tv_episode_code"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:minWidth="32dp"
        android:textColor="#66FFFFFF"
        android:textSize="11sp"
        android:textStyle="bold"
        android:gravity="center"
        android:maxLines="1"
        android:text="E1" />

    <!-- ── Separador vertical sutil ── -->
    <View
        android:layout_width="1dp"
        android:layout_height="20dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:background="#22FFFFFF" />

    <!-- ── Título del episodio — ocupa el resto del ancho ── -->
    <TextView
        android:id="@+id/tv_episode_title"
        android:layout_width="0dp"
        android:layout_weight="1"
        android:layout_height="wrap_content"
        android:textColor="@color/white"
        android:textSize="13sp"
        android:maxLines="2"
        android:ellipsize="end"
        android:lineSpacingExtra="2dp"
        android:text="Título del episodio" />

    <!-- ── Flecha indicadora → siempre visible como hint de navegación ── -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="6dp"
        android:textColor="#33FFFFFF"
        android:textSize="12sp"
        android:text="›" />

</LinearLayout>
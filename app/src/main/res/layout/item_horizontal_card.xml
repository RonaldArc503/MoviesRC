<?xml version="1.0" encoding="utf-8"?>
<!--
    item_horizontal_card.xml  – Card de póster estilo Netflix/REX
    Incluye: badge de rating, imagen de póster, barra de progreso,
             título y año en el área de texto inferior.
    El tamaño real (ancho/alto) lo setea HomeAdapter programáticamente
    según TV o móvil.
-->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    app:cardCornerRadius="8dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="#161A24">

    <!-- Stack vertical: imagen + barra progreso + texto -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- ── ZONA DE IMAGEN ── -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <!-- Poster image -->
            <ImageView
                android:id="@+id/iv_poster"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/placeholder_poster" />

            <!-- Gradiente inferior para legibilidad del rating -->
            <View
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_gravity="bottom"
                android:background="@drawable/bg_poster_gradient_bottom" />

            <!-- Rating badge (esquina superior izquierda) -->
            <TextView
                android:id="@+id/tv_rating"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|start"
                android:layout_margin="6dp"
                android:textColor="#FFC800"
                android:textSize="10sp"
                android:textStyle="bold"
                android:background="@drawable/bg_rating_badge"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:visibility="gone" />

        </FrameLayout>

        <!-- ── BARRA DE PROGRESO (roja, estilo Netflix) ── -->
        <!-- Fondo gris de la barra -->
        <View
            android:id="@+id/progress_bg"
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:background="#2A2D38"
            android:visibility="gone" />

        <!-- Relleno rojo (ancho se setea programáticamente) -->
        <View
            android:id="@+id/progress_fg"
            android:layout_width="0dp"
            android:layout_height="3dp"
            android:background="#E63540"
            android:visibility="gone" />

        <!-- ── ZONA DE TEXTO ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="7dp"
            android:paddingBottom="8dp">

            <TextView
                android:id="@+id/tv_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#D4D6DE"
                android:textSize="11sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tv_year"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#5A5F70"
                android:textSize="10sp"
                android:layout_marginTop="2dp"
                android:maxLines="1"
                android:ellipsize="end" />

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
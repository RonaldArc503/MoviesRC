<?xml version="1.0" encoding="utf-8"?>
<!--
    Mejoras de rendimiento sugeridas para activity_detail.xml
    - Uso de ConstraintLayout para mejor rendimiento
    - Reducción de niveles de anidación
    - ViewStub para vistas condicionales
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app_dark">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ══════ HERO BANNER CON BACKDROP ══════ -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="560dp">

                <!-- Imagen de fondo (backdrop) -->
                <ImageView
                    android:id="@+id/iv_backdrop"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@drawable/placeholder_backdrop"
                    android:contentDescription="Backdrop" />

                <!-- Gradiente superior para toolbar -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:layout_gravity="top"
                    android:background="@drawable/gradient_toolbar_fade" />

                <!-- Gradiente inferior para contenido -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="360dp"
                    android:layout_gravity="bottom"
                    android:background="@drawable/bg_hero_gradient" />

                <!-- Toolbar transparente (mobile) -->
                <androidx.appcompat.widget.Toolbar
                    android:id="@+id/toolbar"
                    android:layout_width="match_parent"
                    android:layout_height="?attr/actionBarSize"
                    android:layout_gravity="top"
                    android:background="@android:color/transparent"
                    app:navigationIcon="@drawable/ic_arrow_back"
                    app:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar" />

                <!-- Botón de regresar (TV) -->
                <ImageView
                    android:id="@+id/iv_back"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_gravity="top|start"
                    android:layout_margin="16dp"
                    android:padding="8dp"
                    android:src="@drawable/ic_arrow_back"
                    android:background="@drawable/bg_back_button_tv"
                    android:clickable="true"
                    android:focusable="true"
                    android:visibility="gone"
                    android:contentDescription="Volver" />

                <!-- Contenido del hero banner -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom"
                    android:orientation="vertical"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:paddingBottom="24dp">

                    <!-- Badges (tipo y calidad) -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:id="@+id/tv_badge_type"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="PELÍCULA"
                            android:textColor="@color/white"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:background="@drawable/badge_red"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp"
                            android:layout_marginEnd="8dp" />

                        <TextView
                            android:id="@+id/tv_badge_quality"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="HD"
                            android:textColor="@color/accentGold"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:background="@drawable/badge_outline"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp" />

                    </LinearLayout>

                    <!-- Título -->
                    <TextView
                        android:id="@+id/tv_title_hero"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Título del Contenido"
                        android:textColor="@color/white"
                        android:textSize="36sp"
                        android:textStyle="bold"
                        android:lineSpacingExtra="2dp"
                        android:shadowColor="#000000"
                        android:shadowDx="2"
                        android:shadowDy="2"
                        android:shadowRadius="6"
                        android:maxLines="3"
                        android:ellipsize="end" />

                    <!-- Metadata (año, rating, temporadas) -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="10dp"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/tv_year_hero"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="2024"
                            android:textColor="@color/accentGold"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <View
                            android:layout_width="5dp"
                            android:layout_height="5dp"
                            android:layout_marginStart="12dp"
                            android:layout_marginEnd="12dp"
                            android:background="@drawable/dot_separator" />

                        <TextView
                            android:id="@+id/tv_rating"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="★ 8.5"
                            android:textColor="@color/ratingGold"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tv_seasons_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:text="3 Temporadas"
                            android:textColor="@color/textSecondary"
                            android:textSize="14sp"
                            android:visibility="gone" />

                    </LinearLayout>

                </LinearLayout>

            </FrameLayout>

            <!-- ══════ CONTENIDO PRINCIPAL ══════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="8dp"
                android:paddingBottom="32dp">

                <!-- Botones de acción -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="24dp">

                    <!-- Botón Reproducir -->
                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btn_play"
                        android:layout_width="0dp"
                        android:layout_height="54dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="10dp"
                        android:background="@drawable/bg_btn_play_red"
                        android:text="▶ Reproducir"
                        android:textColor="@color/white"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textAllCaps="false"
                        android:elevation="2dp" />

                    <!-- Botón Mi Lista -->
                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btn_my_list"
                        android:layout_width="0dp"
                        android:layout_height="54dp"
                        android:layout_weight="1"
                        android:layout_marginStart="10dp"
                        android:background="@drawable/bg_btn_secondary"
                        android:text="+ Mi Lista"
                        android:textColor="@color/white"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textAllCaps="false" />

                </LinearLayout>

                <!-- Sinopsis -->
                <TextView
                    android:id="@+id/tv_synopsis"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="Sinopsis del contenido..."
                    android:textColor="@color/textSecondary"
                    android:textSize="14sp"
                    android:lineSpacingExtra="4dp"
                    android:maxLines="4"
                    android:ellipsize="end" />

                <!-- Toggle "Ver más" para sinopsis (mobile) -->
                <TextView
                    android:id="@+id/tv_synopsis_toggle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="28dp"
                    android:text="Ver más ▼"
                    android:textColor="@color/accentRed"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true"
                    android:padding="4dp" />

                <!-- Géneros (opcional) -->
                <LinearLayout
                    android:id="@+id/ll_genres"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="24dp"
                    android:visibility="gone" />

                <!-- Header de Episodios/Temporadas (mobile) -->
                <LinearLayout
                    android:id="@+id/ll_season_header"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Episodios"
                        android:textColor="@color/textPrimary"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_season_selector"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Temporada 1"
                        android:textColor="@color/textSecondary"
                        android:textSize="14sp"
                        android:background="@drawable/bg_season_selector"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp"
                        android:clickable="true"
                        android:focusable="true" />

                </LinearLayout>

                <!-- Panel de episodios (TV) -->
                <View
                    android:id="@+id/panel_episodes"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:visibility="gone" />

                <!-- RecyclerView de Episodios -->
                <sv.edu.catolica.rex.ui.detalle.WrapContentRecyclerView
                    android:id="@+id/rv_episodes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:visibility="gone" />

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
